<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- App header with icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_shield_location"
                android:contentDescription="@string/app_name" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/module_description"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Module status banner -->
        <TextView
            android:id="@+id/tv_module_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_inactive"
            android:gravity="center"
            android:text="@string/status_inactive"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <View android:layout_width="match_parent" android:layout_height="16dp" />

        <!-- Current snapshot card -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_snapshot"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_snapshot_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/no_snapshot"
                android:textColor="@color/colorOnSurface"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="16dp" />

        <!-- Action buttons -->
        <Button
            android:id="@+id/btn_collect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_primary"
            android:text="@string/btn_collect"
            android:textColor="@color/colorTextPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <View android:layout_width="match_parent" android:layout_height="8dp" />

        <Button
            android:id="@+id/btn_activate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_primary"
            android:text="@string/btn_activate"
            android:textColor="@color/colorTextPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <View android:layout_width="match_parent" android:layout_height="16dp" />

        <!-- Saved profiles section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_profiles"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/ll_profiles_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tv_no_profiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_profiles"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp" />

        <!-- Export / Import buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_export"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_secondary"
                android:text="@string/btn_export"
                android:textColor="@color/colorTextPrimary"
                android:textSize="13sp" />

            <View android:layout_width="8dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btn_import"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_secondary"
                android:text="@string/btn_import"
                android:textColor="@color/colorTextPrimary"
                android:textSize="13sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="16dp" />

        <!-- Stats card -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_stats"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/stats_unavailable"
                android:textColor="@color/colorOnSurface"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
